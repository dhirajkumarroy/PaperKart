<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingHorizontal="16dp">

    <ImageView
        android:id="@+id/ivMenuIcon"
        android:layout_width="24dp" android:layout_height="24dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_notification"
        android:tint="@color/accent_primary" />

    <TextView
        android:id="@+id/tvMenuLabel"
        android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="wrap_content"
        android:text="Menu Item"
        android:textAppearance="@style/TextAppearance.App.Body"
        android:textColor="@color/text_primary" />

    <TextView
        android:id="@+id/tvMenuBadge"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_badge"
        android:paddingHorizontal="6dp" android:paddingVertical="2dp"
        android:textSize="11sp" android:textColor="@color/white"
        android:visibility="gone" />

    <ImageView
        android:layout_width="18dp" android:layout_height="18dp"
        android:src="@drawable/ic_arrow_right"
        android:tint="@color/icon_tint" />

</LinearLayout>