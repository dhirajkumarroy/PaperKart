<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Category chips placeholder -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">
        <View android:layout_width="80dp" android:layout_height="match_parent" android:background="#DDDDDD" android:layout_marginEnd="12dp" />
        <View android:layout_width="80dp" android:layout_height="match_parent" android:background="#DDDDDD" android:layout_marginEnd="12dp" />
        <View android:layout_width="80dp" android:layout_height="match_parent" android:background="#DDDDDD" />
    </LinearLayout>

    <!-- Featured Section Title -->
    <View android:layout_width="120dp" android:layout_height="24dp" android:background="#DDDDDD" android:layout_marginBottom="16dp" />

    <!-- Horizontal cards placeholder -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:orientation="horizontal">
        <View android:layout_width="150dp" android:layout_height="match_parent" android:background="#DDDDDD" android:layout_marginEnd="16dp" />
        <View android:layout_width="150dp" android:layout_height="match_parent" android:background="#DDDDDD" />
    </LinearLayout>

</LinearLayout>
