<?xml version="1.0" encoding="utf-8"?>
<!--
  PaperKart — Home Screen Layout
  All original IDs preserved. Enhanced with:
  • Gradient header background
  • Pill-shaped badge on cart icon
  • Elevated glassy search bar with mic icon
  • Category chip row
  • Smooth ripple states everywhere
  • Banner / promo card slot above RecyclerView
  • Material 3 spacing rhythm
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FC"
    android:fitsSystemWindows="true">

    <!-- ═══════════════════════════════════════════════════
         APP BAR  — gradient header that collapses on scroll
    ═══════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        app:elevation="0dp"
        app:liftOnScroll="true">

        <!-- top status-bar spacer (drawn behind system bar) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Greeting row ── ── ── ── ── ── ── -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.65"
                android:fontFamily="sans-serif"
                android:text="Welcome back,"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:letterSpacing="0.02"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="PaperKart User"
                android:textColor="#1A1A2E"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/cartWrapper"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvWelcome" />

            <!-- Cart icon + badge wrapper ── ── ── -->
            <FrameLayout
                android:id="@+id/cartWrapper"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:layout_constraintBottom_toBottomOf="@id/tvUserName"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvWelcome">

                <!-- Cart touch target -->
                <ImageView
                    android:id="@+id/ivCart"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_cart_btn"
                    android:padding="12dp"
                    android:src="@drawable/ic_cart"
                    app:tint="#1A1A2E" />

                <!-- Item count badge -->
                <TextView
                    android:id="@+id/tvCartBadge"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/bg_badge"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="visible" />

            </FrameLayout>

            <!-- ── Search bar ── ── ── ── ── ── ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/searchCard"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvUserName">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <!-- Search icon -->
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#4F8EF7" />

                    <!-- Hint text -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:fontFamily="sans-serif"
                        android:text="Search products..."
                        android:textColor="#B0B0C0"
                        android:textSize="14sp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="22dp"
                        android:background="#E0E0F0"
                        android:layout_marginEnd="10dp" />

                    <!-- Mic icon -->
                    <ImageView
                        android:id="@+id/ivMic"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="#4F8EF7" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Category chip row ── ── ── ── ── -->
            <HorizontalScrollView
                android:id="@+id/categoryScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:paddingEnd="8dp"
                app:layout_constraintTop_toBottomOf="@id/searchCard">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Chip: All (selected) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_chip_selected"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="All"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"/>

                    <!-- Chip: Notebooks -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_chip_default"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Notebooks"
                        android:textColor="#5A5A7A"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"/>

                    <!-- Chip: Pens -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_chip_default"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Pens"
                        android:textColor="#5A5A7A"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"/>

                    <!-- Chip: Files -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_chip_default"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Files"
                        android:textColor="#5A5A7A"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"/>

                    <!-- Chip: Staplers -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_chip_default"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Staplers"
                        android:textColor="#5A5A7A"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"/>

                </LinearLayout>
            </HorizontalScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- subtle bottom divider line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#0A000020"
            android:alpha="0.06" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══════════════════════════════════════════════════
         MAIN SCROLL BODY
    ═══════════════════════════════════════════════════ -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="80dp"
            tools:listitem="@layout/item_product" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- ═══════════════════════════════════════════════════
         LOADING — centred spinner (gone by default)
    ═══════════════════════════════════════════════════ -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.MaterialComponents.CircularProgressIndicator"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:visibility="gone"
        app:indicatorColor="#4F8EF7" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>


    <!--
    ══════════════════════════════════════════════════════════
      REQUIRED DRAWABLE RESOURCES  (create in res/drawable/)
    ══════════════════════════════════════════════════════════

    ① bg_header_gradient.xml
    ─────────────────────────────────────────────────────────
    <?xml version="1.0" encoding="utf-8"?>
    <shape xmlns:android="http://schemas.android.com/apk/res/android">
        <gradient
            android:type="linear"
            android:angle="135"
            android:startColor="#EAF3FF"
            android:centerColor="#F4EFFF"
            android:endColor="#FFFBEE" />
    </shape>

    ② bg_cart_btn.xml
    ─────────────────────────────────────────────────────────
    <?xml version="1.0" encoding="utf-8"?>
    <ripple xmlns:android="http://schemas.android.com/apk/res/android"
        android:color="#1A4F8EF7">
        <item>
            <shape android:shape="oval">
                <solid android:color="#EAEEFF" />
            </shape>
        </item>
    </ripple>

    ③ bg_badge.xml
    ─────────────────────────────────────────────────────────
    <?xml version="1.0" encoding="utf-8"?>
    <shape xmlns:android="http://schemas.android.com/apk/res/android"
        android:shape="oval">
        <solid android:color="#FF4F8EF7" />
        <stroke android:width="1.5dp" android:color="#FFFFFF" />
    </shape>

    ④ bg_chip_selected.xml
    ─────────────────────────────────────────────────────────
    <?xml version="1.0" encoding="utf-8"?>
    <ripple xmlns:android="http://schemas.android.com/apk/res/android"
        android:color="#334F8EF7">
        <item>
            <shape android:shape="rectangle">
                <solid android:color="#4F8EF7" />
                <corners android:radius="20dp" />
            </shape>
        </item>
    </ripple>

    ⑤ bg_chip_default.xml
    ─────────────────────────────────────────────────────────
    <?xml version="1.0" encoding="utf-8"?>
    <ripple xmlns:android="http://schemas.android.com/apk/res/android"
        android:color="#224F8EF7">
        <item>
            <shape android:shape="rectangle">
                <solid android:color="#F0F2FF" />
                <corners android:radius="20dp" />
                <stroke android:width="1dp" android:color="#DDE0F5" />
            </shape>
        </item>
    </ripple>

    ══════════════════════════════════════════════════════════
      RECOMMENDED item_product.xml CARD (res/layout/)
    ══════════════════════════════════════════════════════════

    Each product card should use:
      • cardCornerRadius="16dp"
      • cardElevation="2dp"
      • cardBackgroundColor="#FFFFFF"
      • Add to cart FAB-mini button bottom-right
      • Product image top with rounded top corners via ShapeableImageView
      • Price in bold #4F8EF7
      • Original price struck-through in #B0B0C0

    ══════════════════════════════════════════════════════════
      SWIPEREFRESH COLOURS  (in styles.xml or themes.xml)
    ══════════════════════════════════════════════════════════

    <item name="colorPrimary">#4F8EF7</item>
    <item name="colorAccent">#FFBE45</item>

    ══════════════════════════════════════════════════════════
      FONTS  (res/font/ — use Google Fonts via downloadable)
    ══════════════════════════════════════════════════════════

    poppins_regular.ttf   — body / hints
    poppins_semibold.ttf  — headings
    (or substitute with fontFamily="sans-serif" / "sans-serif-medium")

    ══════════════════════════════════════════════════════════
    -->